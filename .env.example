# ============================================================
# LandFitness — Environment Variables
# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is gitignored — never commit secrets.
# ============================================================

# ─── Site URL ────────────────────────────────────────────────
# Production domain (no trailing slash). Used by:
#   • metadataBase (canonical, OG image absolute URLs)
#   • sitemap.xml & robots.txt
#   • JSON-LD structured data
# In production:
NEXT_PUBLIC_SITE_URL=https://landfitness.uz
# Local dev (optional override):
# NEXT_PUBLIC_SITE_URL=http://localhost:3000


# ─── Telegram bot (contact form) ─────────────────────────────
# Create a bot via @BotFather on Telegram → copy the token here.
TELEGRAM_BOT_TOKEN=1234567890:AAExampleTokenFromBotFatherXXXXXXXXXX

# Chat ID to receive form submissions.
# For private chat: write to your bot, then visit
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# and copy the `chat.id` field.
# For a group/channel: add the bot, send any message, then getUpdates.
TELEGRAM_CHAT_ID=-1001234567890


# ─── Search Console verification (optional) ──────────────────
# Add these AFTER you register the site:
#   Google: https://search.google.com/search-console
#   Yandex: https://webmaster.yandex.com
# Paste only the content="..." value, not the full meta tag.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=
